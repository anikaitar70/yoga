generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventCategory {
  YOGA
  HEALING
  JUST_ART_LIFE
  RETREATS_AND_TOURS
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  name      String?
  avatarUrl String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  blogPosts BlogPost[]
  events    Event[]
}

model Event {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  location    String
  startsAt    DateTime
  endsAt      DateTime?
  imageUrl    String?
  price       Float?
  category    EventCategory @default(YOGA)
  isFeatured  Boolean  @default(false)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User?  @relation(fields: [authorId], references: [id])
  authorId String?
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  summary     String
  content     String
  coverImageUrl String?
  tags        String[] @default([])
  published   Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User?  @relation(fields: [authorId], references: [id])
  authorId String?
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  subscribedAt DateTime @default(now())
}

model GalleryImage {
  id          String   @id @default(uuid())
  title       String?
  url         String
  altText     String?
  description String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model SiteConfig {
  id             String   @id @default(uuid())
  name           String
  tagline        String
  contactEmail   String
  contactPhone   String
  contactAddress String
  social         Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model HeroSection {
  id               String   @id @default(uuid())
  title            String
  subtitle         String
  primaryCtaLabel  String
  primaryCtaHref   String
  secondaryCtaLabel String
  secondaryCtaHref String
  imageSrc         String
  imageAlt         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AboutPage {
  id         String   @id @default(uuid())
  eyebrow    String
  title      String
  subtitle   String
  imageSrc   String
  imageAlt   String
  paragraphs String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Testimonial {
  id        String            @id @default(uuid())
  quote     String
  name      String
  role      String
  status    TestimonialStatus @default(APPROVED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}
