generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventCategory {
  YOGA
  HEALING
  JUST_ART_LIFE
  RETREATS_AND_TOURS
  RETREAT
  WORKSHOP
  TEACHER_TRAINING
  PHILOSOPHY
  YOGA_NIDRA
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TestimonialSourceType {
  TEXT
  IMAGE
  OCR
}

enum TestimonialDisplayStyle {
  CARD
  HANDWRITTEN
}

enum PageType {
  YOGA
  HEALING
  JUST_ART_LIFE
  ABOUT
}

enum PageSectionType {
  HERO
  IMAGE_TEXT
  GALLERY
  TESTIMONIALS
  EVENTS
  CONTACT
  CUSTOM_TEXT
}

enum PreferredContactMethod {
  WHATSAPP
  CALL
  SMS
  EMAIL
  LINE
  TELEGRAM
  OTHER
}

enum GalleryCategory {
  ART
  YOGA_NIDRA
  EVENTS
  RETREATS
  HEALING
  JAPAN_EVENTS
}

enum CollageLayout {
  MASONRY
  STACKED
  ASYMMETRICAL_GRID
  HERO_SUPPORTING
  HORIZONTAL_STRIP
  FEATURED_SUPPORTING
}

enum HeroMediaMode {
  SINGLE
  ROTATING
  COLLAGE
  FEATURED_COLLECTION
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  name      String?
  avatarUrl String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  blogPosts BlogPost[]
  events    Event[]
}

model Event {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  location    String
  startsAt    DateTime
  endsAt      DateTime?
  imageUrl    String?
  price       Float?
  category    EventCategory @default(YOGA)
  isFeatured  Boolean  @default(false)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User?  @relation(fields: [authorId], references: [id])
  authorId String?
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  summary     String
  content     String
  sections    Json?
  coverImageUrl String?
  tags        String[] @default([])
  published   Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User?  @relation(fields: [authorId], references: [id])
  authorId String?
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  subscribedAt DateTime @default(now())
}

model GalleryCollection {
  id          String          @id @default(uuid())
  slug        String          @unique
  title       String
  description String?
  category    GalleryCategory
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  images   GalleryImage[]
  collages GalleryCollage[]

  @@index([category, sortOrder])
}

model GalleryImage {
  id                 String          @id @default(uuid())
  title              String?
  url                String
  thumbnailUrl       String?
  mediumUrl          String?
  width              Int?
  height             Int?
  uploadPath         String?
  altText            String?
  description        String?
  category           GalleryCategory @default(ART)
  collectionId       String?
  collection         GalleryCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  sourceKey          String?         @unique
  sortOrder          Int             @default(0)
  featuredOnHomepage Boolean         @default(false)
  isPublished        Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([category, isPublished])
  @@index([collectionId, sortOrder])
}

model GalleryCollage {
  id           String          @id @default(uuid())
  name         String
  slug         String          @unique
  layout       CollageLayout   @default(MASONRY)
  category     GalleryCategory
  collectionId String?
  collection   GalleryCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  imageIds     Json            @default("[]")
  isPublished  Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  heroSections HeroSection[]

  @@index([category, isPublished])
  @@index([collectionId])
}

model ContactMessage {
  id                     String                  @id @default(uuid())
  name                   String
  email                  String
  subject                String
  message                String
  preferredContactMethod PreferredContactMethod?
  createdAt              DateTime                @default(now())
}

model PageSection {
  id          String          @id @default(uuid())
  pageType    PageType
  sectionType PageSectionType
  title       String?
  subtitle    String?
  content     String?         @db.Text
  imageUrl    String?
  imageAlt    String?
  sortOrder   Int             @default(0)
  isPublished Boolean         @default(true)
  layout      Json?
  payload     Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([pageType, sortOrder])
}

model SiteConfig {
  id             String   @id @default(uuid())
  name           String
  tagline        String
  contactEmail   String
  contactPhone   String
  contactAddress String
  social         Json
  branding       Json?
  navigation     Json?
  homepageLayout   Json?
  homepageSections Json?
  timelineStyleDefaults Json?
  timelineStyleByPage   Json?
  designSettings        Json?
  designSettingsByPage  Json?
  createdAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model HeroSection {
  id                    String          @id @default(uuid())
  title                 String
  subtitle              String
  primaryCtaLabel       String
  primaryCtaHref        String
  secondaryCtaLabel     String
  secondaryCtaHref      String
  imageSrc              String
  imageAlt              String
  mediaMode             HeroMediaMode   @default(SINGLE)
  rotatingImages        Json?
  collageId             String?
  collage               GalleryCollage? @relation(fields: [collageId], references: [id], onDelete: SetNull)
  featuredCollectionId  String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model AboutPage {
  id         String   @id @default(uuid())
  eyebrow    String
  title      String
  subtitle   String
  imageSrc   String
  imageAlt   String
  paragraphs String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Testimonial {
  id             String                   @id @default(uuid())
  quote          String                   @default("")
  name           String                   @default("")
  role           String                   @default("")
  city           String?
  country        String?
  imageUrl       String?
  imageAlt       String?
  extractedText  String?                  @db.Text
  sourceType     TestimonialSourceType    @default(TEXT)
  displayStyle   TestimonialDisplayStyle  @default(HANDWRITTEN)
  ocrConfidence  Float?
  featured       Boolean                  @default(false)
  sortOrder      Int                      @default(0)
  status         TestimonialStatus        @default(APPROVED)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([status, featured, sortOrder])
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  visitorId String
  viewedAt  DateTime @default(now())

  @@index([viewedAt])
  @@index([path, viewedAt])
  @@index([visitorId, viewedAt])
}

enum DiagnosticCategory {
  UPLOAD_FAILURE
  LOGIN_FAILURE
  CMS_SAVE_FAILURE
  IMAGE_PROCESSING_FAILURE
}

model AppDiagnosticEvent {
  id        String             @id @default(uuid())
  category  DiagnosticCategory
  message   String
  metadata  Json?
  createdAt DateTime           @default(now())

  @@index([category, createdAt])
}

model AdminSession {
  id         String    @id @default(cuid())
  email      String
  ipAddress  String
  userAgent  String?
  loginAt    DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?

  @@index([email, revokedAt])
  @@index([lastSeenAt])
  @@index([revokedAt])
}
