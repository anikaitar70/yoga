# Copy this file to .env on the VPS and replace every placeholder.

NODE_ENV=production
PORT=3000

# Public URL — change only this when migrating domains (no code changes required).
APP_URL=https://yoga.anikait.page

# PostgreSQL (Docker Compose service name: db)
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@db:5432/yoga?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=yoga

# Admin session signing (32+ random characters — server-side only, not shared with users)
ADMIN_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# GitHub OAuth — create at https://github.com/settings/developers
# Callback URL: {APP_URL}/api/admin/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated GitHub account emails allowed to access /admin
ADMIN_ALLOWED_EMAILS=anikaitar@gmail.com,nirvanayogaorg@gmail.com

# Writable upload directory inside the app container
UPLOAD_DIR=/app/public/uploads

# Public site scroll background: aurora | mandala | horizon | ripple
# NEXT_PUBLIC_SITE_BACKGROUND=aurora

# Legacy aliases — optional; APP_URL takes precedence
# SITE_URL=https://yoga.anikait.page
# NEXT_PUBLIC_SITE_URL=https://yoga.anikait.page

# Development-only (do not set in production)
# NGROK_DEV_ORIGIN=
# ADMIN_FORCE_SECURE_COOKIE=true
# ADMIN_AUTH_DEBUG=false
# CONTENT_FETCH_DELAY_MS=0
